# soul-avatar-matcher configuration
# Copy this file to .env and fill in your values

# Encryption key for SQLCipher vault (REQUIRED — change this!)
SQLCIPHER_KEY=change-me-in-production

# Database path
SQLCIPHER_DB_PATH=data/personality_vault.db

# Ollama (local SLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# External LLM APIs (optional — set to enable premium reports)
# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# gRPC server
GRPC_HOST=[::]:50051
GRPC_MAX_WORKERS=10

# Compatibility scoring
COMPATIBILITY_THRESHOLD=0.90
VECTOR_WEIGHT=0.60
DIALOGUE_WEIGHT=0.40

# Folder 3/5 API endpoints (for behavioral data ingestion)
FOLDER3_API_URL=http://localhost:8001
FOLDER5_API_URL=http://localhost:8002
INGESTION_TIMEOUT=30

# Drift detection
DRIFT_ALERT_THRESHOLD=0.15

# Logging
LOG_LEVEL=INFO
